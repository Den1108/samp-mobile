<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Интернет и сеть -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Установка APK -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
        Хранилище:
        - WRITE_EXTERNAL_STORAGE работает только до Android 9 (API 28).
        - На Android 10+ используем getExternalFilesDir() — разрешение НЕ нужно.
        - READ_EXTERNAL_STORAGE нужен на Android 9 и ниже если читаем чужие файлы.
        - maxSdkVersion="28" — не запрашиваем у пользователей Android 10+ лишнее разрешение.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Нужно для WorkManager на некоторых устройствах -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:label="Flyt Mobile"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@style/Theme.Flyt">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".DownloadActivity"
            android:exported="false" />

        <!--
            MainGTA — активити игрового движка.
            Если .so библиотеки подключены и движок запускается отдельным Activity —
            оставь этот блок. Если движок запускается иначе — убери.
        -->
        <activity
            android:name=".MainGTA"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <!-- FileProvider для установки APK через installApk() в PlayFragment -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
